# Server
PORT=3456

# Pancake POS
PANCAKE_POS_API_KEY=your_pancake_pos_api_key
PANCAKE_POS_BASE_URL=https://pos.pages.fm/api/v1
PANCAKE_SHOP_ID=your_shop_id

# Pancake Chat
PANCAKE_CHAT_PAGE_TOKEN=your_page_token
PANCAKE_CHAT_BASE_URL=https://pages.fm/api/public_api/v1
PANCAKE_CHAT_PAGE_ID=your_page_id

# Getfly CRM
GETFLY_API_KEY=your_getfly_api_key
GETFLY_BASE_URL=https://your-company.getflycrm.com

# Webhook
WEBHOOK_SECRET=your_webhook_secret

# Admin Login
ADMIN_USER=admin
ADMIN_PASS=Admin@123
SESSION_SECRET=change-this-to-random-string

# Sync Settings
ORDER_SYNC_INTERVAL=300000
ORDER_SYNC_DAYS=2
CHAT_POLL_INTERVAL=30000
